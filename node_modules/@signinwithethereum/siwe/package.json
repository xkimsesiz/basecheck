{
  "name": "@signinwithethereum/siwe",
  "version": "4.2.0",
  "type": "module",
  "description": "Sign in with Ethereum (SIWE)",
  "main": "dist/siwe.cjs",
  "module": "dist/siwe.mjs",
  "types": "dist/siwe.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/siwe.d.ts",
        "default": "./dist/siwe.mjs"
      },
      "require": {
        "types": "./dist/siwe.d.ts",
        "default": "./dist/siwe.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "author": "Ethereum Identity Foundation",
  "license": "Apache-2.0",
  "keywords": [
    "ethereum",
    "sign-in",
    "sign-in-with-ethereum",
    "siwe"
  ],
  "homepage": "https://github.com/signinwithethereum/siwe",
  "dependencies": {
    "@signinwithethereum/siwe-parser": "^4.2.0"
  },
  "devDependencies": {
    "ethers5": "npm:ethers@^5.7.0",
    "ethers6": "npm:ethers@^6.13.0",
    "viem": "^2.7.0"
  },
  "peerDependencies": {
    "ethers": "^5.7.0 || ^6.13.0",
    "viem": "^2.7.0"
  },
  "peerDependenciesMeta": {
    "ethers": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/signinwithethereum/siwe.git"
  },
  "bugs": {
    "url": "https://github.com/signinwithethereum/siwe/issues"
  },
  "scripts": {
    "test": "vitest run",
    "build": "vite build",
    "lint": "eslint .",
    "format": "prettier --ignore-path .gitignore --write \"**/*.+(js|ts|json)\""
  }
}