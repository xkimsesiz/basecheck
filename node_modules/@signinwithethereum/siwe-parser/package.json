{
  "name": "@signinwithethereum/siwe-parser",
  "version": "4.2.0",
  "type": "module",
  "description": "Parse Messages that conform to EIP-4361: Sign in with Ethereum (SIWE)",
  "main": "dist/parsers.cjs",
  "module": "dist/parsers.mjs",
  "types": "dist/parsers.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/parsers.d.ts",
        "default": "./dist/parsers.mjs"
      },
      "require": {
        "types": "./dist/parsers.d.ts",
        "default": "./dist/parsers.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "author": "Ethereum Identity Foundation",
  "keywords": [
    "ethereum",
    "sign-in",
    "sign-in-with-ethereum",
    "siwe",
    "siwe-parser",
    "sign-in-with-ethereum-parser"
  ],
  "homepage": "https://github.com/signinwithethereum/siwe",
  "license": "Apache-2.0",
  "dependencies": {
    "@noble/hashes": "^1.7.0",
    "apg-js": "^4.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/signinwithethereum/siwe.git"
  },
  "bugs": {
    "url": "https://github.com/signinwithethereum/siwe/issues"
  },
  "scripts": {
    "test": "vitest run",
    "build": "vite build",
    "lint": "eslint .",
    "format": "prettier --ignore-path .gitignore --write \"**/*.+(js|ts|json)\"",
    "apg": "apg -i ./lib/siwe-abnf.txt -o ./lib/siwe-grammar --typescript"
  }
}